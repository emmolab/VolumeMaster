{
  "name": "volume-master",
  "version": "1.3.1",
  "description": "VolumeMaster configuration software",
  "main": "src/main.js",
  "author": "William Spalding",
  "license": "ISC",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.williamspalding.volumemaster",
    "productName": "VolumeMaster",
    "files": [
      "dist/**/*",
      "src/**/*",
      "assets/**/*",
      "renderer.html",
      "config.yaml",
      "VolumeMaster-Headless.exe",
      "!**/node_modules/@tailwindcss/oxide-wasm32-wasi",
      "!**/node_modules/@emnapi",
      "!**/node_modules/@esbuild"
    ],
    "extraResources": [
      {
        "from": "VolumeMaster-Headless.exe",
        "to": "VolumeMaster-Headless.exe"
      }
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "src/assets/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/postcss": "^4.2.2",
    "icojs": "^0.20.1",
    "naudiodon": "^2.3.6",
    "ps-list": "^8.1.1",
    "serialport": "^13.0.0",
    "tree-kill": "^1.2.2",
    "x64": "^1.0.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@electron/fuses": "^1.8.0",
    "autoprefixer": "^10.4.27",
    "electron": "^37.2.0",
    "electron-builder": "^26.8.1",
    "electron-reloader": "^1.2.3",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "postcss-loader": "^8.2.1",
    "tailwindcss": "^4.2.2"
  }
}
