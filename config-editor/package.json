{
  "name": "volume-master",
  "version": "1.0.0",
  "main": "src/main.js",
  "renderer": "src/renderer.js",
  "description": "A simple Electron app to manage VoiceMaster configurations",
  "author": "William Spalding",
  "license": "ISC",
  "scripts": {
    "start": "electron-forge start",
    "build:css": "npx tailwindcss -i ./src/tailwind.css -o ./dist/tailwind.output.css --watch",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.williamspalding.volumemaster",
    "productName": "VolumeMaster",
    "files": [
      "dist/**/*",
      "src/**/*",
      "assets/**/*",
      "main.js",
      "preload.js",
      "renderer.html",
      "config.yaml"
    ],
    "extraResources": [
      "assets/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.1.11",
    "@tailwindcss/postcss": "^4.1.11",
    "electron-squirrel-startup": "^1.0.1",
    "extract-file-icon": "^0.3.2",
    "ps-list": "^8.1.1",
    "serialport": "^13.0.0",
    "sharp": "^0.34.2",
    "tree-kill": "^1.2.2",
    "x64": "^1.0.0",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.1",
    "@electron-forge/maker-deb": "^7.8.1",
    "@electron-forge/maker-rpm": "^7.8.1",
    "@electron-forge/maker-squirrel": "^7.8.1",
    "@electron-forge/maker-zip": "^7.8.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.8.1",
    "@electron-forge/plugin-fuses": "^7.8.1",
    "@electron/fuses": "^1.8.0",
    "autoprefixer": "^10.4.21",
    "electron": "^37.2.0",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-loader": "^8.1.1",
    "tailwindcss": "^4.1.11"
  }
}
